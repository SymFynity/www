---
const nav = [
  { href: "/#how", text: "How it works" },
  { href: "/#open", text: "Open source" },
  { href: "/pricing", text: "Pricing" },
  { href: "/about", text: "About" },
  { href: "https://github.com/SymFynity", text: "GitHub", external: true },
];
---

<header class="masthead">
  <a class="wordmark" href="/">Sym<span class="fyn">Fyn</span>ity</a>
  <nav class="nav" aria-label="Primary">
    {
      nav.map((item) => (
        <a
          href={item.href}
          rel={item.external ? "noopener" : undefined}
        >
          {item.text}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .masthead {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 1.25rem;
    border-bottom: 1px solid var(--rule);
    flex-wrap: wrap;
  }

  .wordmark {
    font-family: var(--mono);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
    white-space: nowrap;
  }

  .fyn {
    color: var(--brass);
  }

  .nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .nav a {
    font-family: var(--mono);
    font-size: var(--fs-small);
    color: var(--ink-muted);
    text-decoration: none;
    padding-block: 0.25rem;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .nav a:hover,
  .nav a:focus-visible {
    color: var(--ink);
    border-bottom-color: var(--brass);
  }
</style>
