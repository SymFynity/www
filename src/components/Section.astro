---
interface Props {
  id?: string;
  label: string;
  heading: string;
  /**
   * Heading level. Pages without a Hero use `h1` on their first Section so the
   * document outline starts at h1 — the homepage gets its h1 from the Hero.
   */
  as?: "h1" | "h2";
  /** Drop the top rule where the section is the first thing on the page. */
  lead?: boolean;
}

const {
  id,
  label,
  heading,
  as: Heading = "h2",
  lead = false,
}: Props = Astro.props;
---

<section class="section" id={id} class:list={{ lead }}>
  <div class="section-head">
    <span class="label">{label}</span>
    <Heading class="heading">{heading}</Heading>
  </div>
  <slot />
</section>

<style>
  .section {
    padding-block: var(--gap-section);
    border-top: 1px solid var(--rule);
  }

  .section.lead {
    border-top: none;
    padding-top: clamp(3rem, 8vw, 5rem);
  }

  .section-head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .heading {
    font-family: var(--mono);
    font-size: var(--fs-h2);
    letter-spacing: -0.02em;
    font-weight: 600;
    margin: 0;
    text-wrap: balance;
  }

  h1.heading {
    font-size: clamp(1.75rem, 3.6vw, 2.5rem);
    letter-spacing: -0.03em;
  }
</style>
