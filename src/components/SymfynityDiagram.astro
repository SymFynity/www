---
/*
 * The hero thesis: rather than describe the circuit breaker, run one.
 *
 * Chunks stream the channel, the rolling budget fills, and at 100% the next
 * chunk is stopped dead at the symfynity and the stream closes with budget_blocked.
 * Then it resets and loops.
 *
 * Self-contained: knows nothing about page content. Reads its colours from the
 * design tokens and re-reads them when the viewer's theme changes.
 */
---

<figure class="instrument">
  <figcaption class="instrument-head">
    <span class="label">symfynity · acct_123</span>
    <span class="readout" data-readout>
      <span class="label">budget</span>
      <span class="val" data-budget>0%</span>
    </span>
  </figcaption>

  <canvas
    data-symfynity-canvas
    role="img"
    aria-label="Diagram of SymFynity enforcing a token budget. Response chunks stream left to right through the proxy while the tenant is under budget. When the budget is exhausted the next chunk is stopped at the proxy, and the connection closes with a budget_blocked event."
  ></canvas>

  <div class="instrument-foot" data-event-line>&nbsp;</div>
</figure>

<style>
  .instrument {
    margin: 0;
    background: var(--ground-2);
    border: 1px solid var(--rule);
    box-shadow: 0 1px 3px var(--shadow);
  }

  .instrument-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 0.875rem;
    border-bottom: 1px solid var(--rule);
  }

  .readout {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: var(--fs-label);
    letter-spacing: 0.1em;
  }

  .val {
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }

  .readout[data-tripped] .val {
    color: var(--trip);
  }

  canvas {
    display: block;
    width: 100%;
    height: 268px;
  }

  .instrument-foot {
    padding: 0.6rem 0.875rem;
    border-top: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: var(--fs-label);
    color: var(--ink-muted);
    letter-spacing: 0.06em;
    min-height: 2.1rem;
  }

  .instrument-foot :global(.evt) {
    color: var(--trip);
  }
</style>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>("[data-symfynity-canvas]");
  const budgetEl = document.querySelector<HTMLElement>("[data-budget]");
  const eventEl = document.querySelector<HTMLElement>("[data-event-line]");
  const readoutEl = document.querySelector<HTMLElement>("[data-readout]");

  if (canvas && budgetEl && eventEl && readoutEl) {
    const ctx = canvas.getContext("2d")!;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)");

    // Tuned so the trip — the whole point of the diagram — lands within about
    // five seconds and the full cycle runs ~8s. Slower than this and the payoff
    // arrives after the reader has already scrolled past it.
    const SPEED = 132; // px per second
    const COST = 0.14; // budget fraction consumed per chunk (~8 chunks to full)
    const SPAWN = 350; // ms between chunks
    const HOLD = 2200; // ms to hold the tripped state before resetting

    const TRIP_EVENT =
      '<span class="evt">✕ chunk withheld</span> · 429 · outcome=budget_blocked · stream closed';

    type Chunk = { x: number; w: number; judged?: boolean; stopped?: boolean };

    let W = 0;
    let H = 0;
    let chunks: Chunk[] = [];
    let budget = 0;
    let state: "flowing" | "tripped" = "flowing";
    let resetAt = 0;
    let spawnAt = 0;
    let last = 0;
    let spawned = 0;

    const tokens = {
      flow: "",
      brass: "",
      trip: "",
      rule: "",
      muted: "",
    };

    function readTokens() {
      const s = getComputedStyle(document.documentElement);
      tokens.flow = s.getPropertyValue("--flow").trim();
      tokens.brass = s.getPropertyValue("--brass").trim();
      tokens.trip = s.getPropertyValue("--trip").trim();
      tokens.rule = s.getPropertyValue("--rule").trim();
      tokens.muted = s.getPropertyValue("--ink-muted").trim();
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const r = canvas!.getBoundingClientRect();
      W = r.width;
      H = r.height;
      canvas!.width = Math.round(W * dpr);
      canvas!.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    const gateX = () => W * 0.66;
    const laneY = () => H * 0.46;

    function reset() {
      chunks = [];
      budget = 0;
      state = "flowing";
      eventEl!.innerHTML = "&nbsp;";
      readoutEl!.removeAttribute("data-tripped");
    }

    function trip(c: Chunk, now: number) {
      c.x = gateX() - c.w;
      c.stopped = true;
      state = "tripped";
      resetAt = now + HOLD;
      readoutEl!.setAttribute("data-tripped", "");
      eventEl!.innerHTML = TRIP_EVENT;
    }

    function update(dt: number, now: number) {
      if (state === "tripped") {
        if (now >= resetAt) reset();
        return;
      }

      if (now >= spawnAt) {
        spawnAt = now + SPAWN;
        // deterministic size variation — no RNG, so the loop is reproducible
        chunks.push({ x: -18, w: 12 + (spawned++ % 5) * 3 });
      }

      for (let i = chunks.length - 1; i >= 0; i--) {
        const c = chunks[i];
        c.x += SPEED * dt;

        if (!c.judged && c.x + c.w >= gateX()) {
          c.judged = true;
          if (budget + COST <= 1) budget += COST;
          else trip(c, now);
        }

        if (c.x > W + 40) chunks.splice(i, 1);
      }

      budgetEl!.textContent = `${Math.round(budget * 100)}%`;
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);
      const y = laneY();
      const wx = gateX();
      const tripped = state === "tripped";

      // channel bed
      ctx.strokeStyle = tokens.rule;
      ctx.lineWidth = 1;
      for (const edge of [y - 26.5, y + 26.5]) {
        ctx.beginPath();
        ctx.moveTo(0, edge);
        ctx.lineTo(W, edge);
        ctx.stroke();
      }

      // gauge ticks — this is a measuring instrument
      for (let t = 0; t < W; t += 16) {
        ctx.beginPath();
        ctx.moveTo(t + 0.5, y + 26.5);
        ctx.lineTo(t + 0.5, y + 31.5);
        ctx.stroke();
      }

      // traffic
      for (const c of chunks) {
        const passed = c.judged && !c.stopped;
        ctx.fillStyle = c.stopped ? tokens.trip : tokens.flow;
        ctx.globalAlpha = c.stopped ? 1 : passed ? 0.55 : 0.9;
        ctx.fillRect(c.x, y - 7, c.w, 14);
      }
      ctx.globalAlpha = 1;

      // the symfynity
      ctx.strokeStyle = tripped ? tokens.trip : tokens.brass;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(wx, y - 40);
      ctx.lineTo(wx, y + 40);
      ctx.stroke();
      ctx.fillStyle = tripped ? tokens.trip : tokens.brass;
      ctx.fillRect(wx - 4, y - 44, 8, 5);
      ctx.fillRect(wx - 4, y + 39, 8, 5);
      ctx.font = '500 9px ui-monospace, SFMono-Regular, Menlo, monospace';
      ctx.textAlign = "center";
      ctx.fillText("SYMFYNITY", wx, y - 51);

      // rolling budget gauge
      const gx = 16;
      const gw = W - 32;
      const gy = H - 30;
      ctx.strokeStyle = tokens.rule;
      ctx.lineWidth = 1;
      ctx.strokeRect(gx + 0.5, gy + 0.5, gw - 1, 9);
      ctx.fillStyle = budget >= 1 ? tokens.trip : tokens.brass;
      ctx.fillRect(gx + 1, gy + 1, Math.max(0, (gw - 2) * Math.min(budget, 1)), 8);

      ctx.font = '500 8.5px ui-monospace, SFMono-Regular, Menlo, monospace';
      ctx.fillStyle = tokens.muted;
      ctx.textAlign = "left";
      ctx.fillText("ROLLING TOKEN BUDGET · 60s WINDOW", gx, gy - 7);
      ctx.textAlign = "right";
      ctx.fillText("50,000", gx + gw, gy - 7);
    }

    function frame(now: number) {
      if (!last) last = now;
      const dt = Math.min((now - last) / 1000, 0.05);
      last = now;
      update(dt, now);
      draw();
      requestAnimationFrame(frame);
    }

    // Reduced motion still gets the point — the moment that matters, held still.
    function staticFrame() {
      chunks = [
        { x: W * 0.1, w: 15, judged: true },
        { x: W * 0.28, w: 18, judged: true },
        { x: W * 0.44, w: 12, judged: true },
        { x: gateX() - 16, w: 16, judged: true, stopped: true },
      ];
      budget = 1;
      state = "tripped";
      budgetEl!.textContent = "100%";
      readoutEl!.setAttribute("data-tripped", "");
      eventEl!.innerHTML = TRIP_EVENT;
      draw();
    }

    function boot() {
      readTokens();
      resize();
      if (reduced.matches) staticFrame();
      else {
        last = 0;
        requestAnimationFrame(frame);
      }
    }

    window.addEventListener("resize", () => {
      resize();
      if (reduced.matches) staticFrame();
    });

    // The canvas can't inherit CSS, so re-read the tokens when the reader
    // switches their OS theme with the page already open.
    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", () => {
        readTokens();
        if (reduced.matches) staticFrame();
      });

    boot();
  }
</script>
